# --- Required ---

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=replace-with-botfather-token

# Your Telegram user ID (get it from @userinfobot). Only this user can talk to the bot.
ALLOWED_USER_IDS=[123456789]

# --- Optional ---

# Deepgram API key for voice-to-text (required only for voice messages).
# Sign up at https://deepgram.com. Leave empty if you don't need voice.
DEEPGRAM_API_KEY=

# UI language: "en" (default) or "ru"
BOT_LANG=en

# Workspace/vault directory for file-saving agent skills (research dumps,
# generated files). Recommended: an Obsidian vault synced to your computer
# with Syncthing (see README "Recommended Setup"). Leave empty to disable.
VAULT=

# Project root (used to resolve relative paths). Default: current dir.
PROJECT_ROOT=.

# Default working directory for new topics. Keep "." for the public bot.
DEFAULT_CWD=.

# Where the bot saves downloaded media (photos, documents) for CC to read.
FILE_CACHE_DIR=./data

# Path to topic config (mode + cwd + system prompt per Telegram topic).
TOPIC_CONFIG_PATH=./topic_config.json

# Where tmux session state is stored.
TMUX_SESSIONS_DIR=./tmux_sessions

# Agent defaults
# Model is configured per topic in topic_config.json with the "model" field.
CC_MAX_TURNS=100
CC_INACTIVITY_KILL_SEC=1800

# Optional: chat ID where notifications go. Defaults to first allowed_user_id.
# NOTIFICATION_CHAT_ID=replace-with-chat-id

# --- Optional features ---

# Canned reply for users NOT in ALLOWED_USER_IDS. Empty = ignore silently.
# UNAUTHORIZED_REPLY=Sorry, this is a private bot.
# Cooldown between canned replies to the same stranger, seconds.
# UNAUTHORIZED_REPLY_COOLDOWN_SEC=600

# Prefix prompts with "[Message from: <name>]" in shared bots:
# auto (default, only when >1 allowed user) | always | never.
# ATTRIBUTE_SENDERS=auto

# Ask the agent to write a checkpoint of the session before /new or /clear
# drops the context. CHECKPOINT_PROMPT overrides the built-in prompt text.
# CHECKPOINT_ON_RESET=false
# CHECKPOINT_PROMPT=

# Session and query limits (seconds).
# SESSION_TIMEOUT_SEC=86400
# CC_QUERY_TIMEOUT_SEC=600

# Voice transcription fallbacks (exotic; most users only need Deepgram).
# fluidaudio: macOS/Apple Silicon local engine (Parakeet models).
# FLUIDAUDIO_CLI_PATH=
# FLUIDAUDIO_MODEL_DIR=
# Yandex SpeechKit: folder ID + service-account key JSON.
# YANDEX_FOLDER_ID=
# YANDEX_SA_KEY_JSON=

# --- Self-heal & monitoring ---

# Dead-man heartbeat receiver (e.g. a healthchecks.io ping URL).
# The bot POSTs once a minute; the receiver alerts you when pings stop.
# Leave empty to disable. Keep the URL secret — anyone who has it can ping.
HEARTBEAT_URL=
# Shared secret sent as X-Heartbeat-Secret header (for self-hosted receivers;
# healthchecks.io ignores it). Generate: openssl rand -hex 32
HEARTBEAT_SECRET=

# Self-rotating log file (10 MB x 3). Empty = log to stdout (then your service
# manager owns the log file and must rotate it itself, which launchd can't).
LOG_FILE=
